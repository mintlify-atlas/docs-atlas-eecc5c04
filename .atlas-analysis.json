  "keyFeatures": [
    "Multi-tenant company management with role-based access control",
    "Comprehensive aircraft and component tracking system",
    "Warehouse and inventory management with batch tracking",
    "Purchase order and requisition workflow",
    "Aviation maintenance work order system",
    "SMS (Safety Management System) with incident reporting",
    "Financial management including credits and payments",
    "Flight control and scheduling",
    "Real-time notifications using Laravel Echo and Pusher",
    "PDF generation for reports and documents",
    "Interactive dashboards with role-specific views"
  ],
  "publicApiSurface": [
    "useAuth() - Authentication context hook",
    "useCompanyStore() - Company state management",
    "AuthContext - User authentication and session management",
    "axiosInstance - Configured HTTP client",
    "DataTableMixedSorting - Sortable data table component",
    "WarehouseDashboard - Warehouse overview component",
    "SMSDashboard - Safety management dashboard",
    "AdministrationDashboard - Financial management dashboard",
    "User type - User account with roles and permissions",
    "Article type - Warehouse article/component",
    "Aircraft type - Aircraft entity with tracking",
    "WorkOrder type - Maintenance work order",
    "Requisition type - Purchase requisition",
    "PurchaseOrder type - Purchase order",
    "Credit type - Credit/payment tracking",
    "ObligatoryReport type - Mandatory safety incident report",
    "VoluntaryReport type - Voluntary safety report"
  ]
